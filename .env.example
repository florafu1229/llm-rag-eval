# Copy this file to `.env` and fill in your values.
#
# The project talks to any OpenAI-compatible endpoint (OpenAI, Azure OpenAI,
# a local vLLM/Ollama server, or any OpenAI-compatible gateway). Both the
# answering agent and the DeepEval judge use these settings.

# API key for the LLM endpoint. For local Ollama any non-empty value works.
OPENAI_API_KEY=ollama

# Base URL of the OpenAI-compatible endpoint.
#   local Ollama:  http://localhost:11434/v1   (default below)
#   local vLLM:    http://localhost:8000/v1
#   OpenAI:        https://api.openai.com/v1
OPENAI_BASE_URL=http://localhost:11434/v1

# Model used by the ANSWERING agent (the system under test)
AGENT_MODEL=qwen2.5:3b

# Model used by the DeepEval JUDGE (ideally a stronger model; reuse agent model if low on resources)
JUDGE_MODEL=qwen2.5:3b
